{
  "version": 2,
  "builds": [
    {
      "src": "React/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "Express/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Express/app.js"
    },
    {
      "src": "/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "React/$1"
    },
    {
      "src": "/(.*)",
      "dest": "React/index.html"
    }
  ]
}